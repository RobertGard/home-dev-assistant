      "parameters": {
        "jsCode": "// Берём все входные элементы\nconst data = $('Получаем папки клиентов').all();\n\n// Формируем inline-клавиатуру из всех элементов\nconst inline_keyboard = data.map(item => {\n  const path = item.json.path;\n  const folderName = decodeURIComponent(path.split('/').slice(-2, -1)[0]);\n\n  return [\n    {\n      text: folderName,\n      callback_data: `open_${path}`\n    }\n  ];\n});\n\n// Возвращаем один общий объект\nreturn [\n  {\n    json: {\n      reply_markup: {\n        inline_keyboard\n      }\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        656,
