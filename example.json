      "parameters": {
        "jsCode": "// Берём первый элемент\nconst item = $input.first();\n\nconst binary = item.binary?.characteristics;\nif (!binary?.data) {\n  return [{ json: { error: 'no binary characteristics' } }];\n}\n\n// В n8n есть встроенный global Buffer\nconst buf = Buffer.from(binary.data, 'base64'); // преобразуем base64 в байты\nconst text = buf.toString('utf8'); // если текст\n\n// Парсим JSON, если нужно\nlet parsed = null;\ntry { parsed = JSON.parse(text); } catch (e) {}\n\nreturn [{\n  json: {\n    filename: binary.fileName || null,\n    mimeType: binary.mimeType || null,\n    text,\n    json: parsed\n  }\n}];\n"
      },
