      "parameters": {
        "jsCode": "// --- Входной массив файлов\nconst files = $input.all(); // массив объектов n8n\n\n// --- Настройки из отдельного Set Node (или переменных)\nconst vars = $('Задаём переменные').first().json;\nconst username = vars.nextcloud_login;\nconst password = vars.nextcloud_pass;\nconst domain = vars.nextcloud_domain;\nconst baseUrl = `http://${encodeURIComponent(username)}:${encodeURIComponent(password)}@${domain}/remote.php/webdav/`;\n\n// --- Настройки фильтра\nconst scaleFilter = vars.scale_filter || 'scale=832:832:force_original_aspect_ratio=decrease,pad=832:832:(ow-iw)/2:(oh-ih)/2';\n\n// --- Генерация строки FFmpeg inputs\nconst ffmpegInputs = files\n  .map(file => `-i \"${baseUrl}${file.json.path}\"`)\n  .join(' ');\n\n// --- Генерация фильтра для каждого видео\nconst filterParts = files.map((file, index) => `[${index}:v]${scaleFilter}[v${index}]`).join(';');\n\n// --- Конкатенация всех видео\nconst concatInputs = files.map((file, index) => `[v${index}]`).join('');\nconst concatFilter = `${concatInputs}concat=n=${files.length}:v=1:a=0[outv]`;\n\n// --- Полный filter_complex\nconst filterComplex = `${filterParts};${concatFilter}`;\n\n// --- Возврат в n8n\nreturn [\n  {\n    json: {\n      ffmpegInputs,\n      filterComplex\n    }\n  }\n];\n"
      },
