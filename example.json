      "id": "73b7e54e-a438-442b-87f1-c1cef7d3c571",
      "name": "Преобразуем папки клиентов в подкоманды"
    },
    {
      "parameters": {
        "jsCode": "const folders = $('Получаем папки клиентов').all();\n// Берём callback_data, если есть, иначе текст сообщения\nconst telegram = $('Telegram Trigger').first().json;\nconst callbackData = telegram.callback_query?.data || telegram.message?.text || null;\n\n// Извлекаем path из callbackData\nconst match = callbackData.match(/^open_(.+)$/);\nconst path = match ? match[1] : null;\n\n// Проверяем, есть ли такой path в списке\nconst exists = !!(path && folders.some(f => f.json.path === path));\n\nreturn [\n  {\n    json: {\n      callbackData,\n      path: path ? decodeURIComponent(path) : null,\n      isKnown: exists\n    }\n  }\n];\n"
      },
