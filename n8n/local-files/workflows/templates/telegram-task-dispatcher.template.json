      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const route = $('Prepare Dispatch').first().json\nconst task = route.task\nconst response = $json\nif (route.transportError) { return [{ task, response, sessionId: route.sessionId, status: 'failed', question: '', optionsJson: '[]', replyText: `Ошибка запуска задачи: ${route.transportError}`, askMessage: '', continueUrl: route.messageUrl, authHeader: route.authHeader, opencodeAgent: route.opencodeAgent }] }\nif (response.error) { return [{ task, response, sessionId: route.sessionId, status: 'failed', question: '', optionsJson: '[]', replyText: `Ошибка OpenCode: ${String(response.error.message || response.error)}`, askMessage: '', continueUrl: route.messageUrl, authHeader: route.authHeader, opencodeAgent: route.opencodeAgent }] }\nconst textParts = Array.isArray(response.parts) ? response.parts.filter((p) => p.type === 'text').map((p) => p.content || p.text || '') : []\nconst rawText = textParts.join('\\n').trim() || JSON.stringify(response)\nconst lines = rawText.split(/\\r?\\n/).map((line) => line.trim()).filter(Boolean)\nconst optionRegex = /^(?:\\d+[\\.\\)]|[-*•])\\s+(.+)$/\nconst optionLines = lines.map((line) => { const m = line.match(optionRegex); return m ? m[1].trim() : null }).filter(Boolean)\nconst options = optionLines.map((value) => ({ label: value, value }))\nconst status = options.length > 0 ? 'needs_input' : 'done'\nconst optionsText = options.length ? '\\n\\nВарианты ответа:\\n' + options.map((o, i) => `${i + 1}. ${o.label}`).join('\\n') : ''\nreturn [{ task, response, sessionId: route.sessionId, status, question: options.length ? rawText : '', optionsJson: JSON.stringify(options), replyText: rawText, askMessage: `${rawText}${optionsText}`.trim(), continueUrl: route.messageUrl, authHeader: route.authHeader, opencodeAgent: route.opencodeAgent }]"
      },
      "id": "classify-result",
      "name": "Classify Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
