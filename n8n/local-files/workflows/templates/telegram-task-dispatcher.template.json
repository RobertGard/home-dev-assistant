        }
      },
      "id": "resume-running",
      "name": "Resume Running",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
      "position": [4160, 220]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$json.continueUrl}}",
        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "Authorization", "value": "={{$json.authHeader}}" }, { "name": "Content-Type", "value": "application/json" }] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { agent: $json.opencodeAgent, parts: [{ type: 'text', content: $json.continuationText }] } }}",
        "options": { "response": { "response": { "responseFormat": "json" } }, "timeout": 1800000 }
      },
      "id": "send-continuation",
      "name": "Send Continuation",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [4420, 220]
    },
    {
      "parameters": {
        "jsCode": "const task = $('Pick Task').first().json.task\nconst result = $('Classify Result').first().json\nreturn [{ task, result, replyText: result.replyText || `Задача ${task.task_key} выполнена.` }]"
      },
      "id": "prepare-success",
      "name": "Prepare Success",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3380, 420]
    },
    {
      "parameters": {
        "resource": "row",
        "operation": "update",
        "dataTableId": {
          "mode": "id",
          "value": "__TASKS_TABLE_ID__"
        },
