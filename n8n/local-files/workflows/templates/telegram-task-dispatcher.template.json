      "id": "create-session",
      "name": "Create Session",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1820, 320],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const route = $('Pick Task').first().json\nconst sessionResponse = $json\nif (sessionResponse.error) { return [{ ...route, sessionId: '', promptText: '', messageUrl: '', commandUrl: '', transportError: String(sessionResponse.error.message || sessionResponse.error || 'session create failed') }] }\nconst sessionId = sessionResponse.id || sessionResponse.data?.id || sessionResponse.sessionId\nif (!sessionId) { return [{ ...route, sessionId: '', promptText: '', messageUrl: '', commandUrl: '', transportError: 'Не удалось получить sessionId' }] }\nconst promptText = [ ...(route.context || []).map((item) => String(item)), String(route.task.prompt || '') ].filter(Boolean).join('\\n\\n')\nreturn [{ ...route, sessionId, promptText, messageUrl: route.endpoints.sessionMessage.replace(':id', sessionId), commandUrl: route.endpoints.sessionCommand.replace(':id', sessionId), transportError: '' }]"
      },
