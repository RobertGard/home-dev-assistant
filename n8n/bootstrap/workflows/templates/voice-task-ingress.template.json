{
  "name": "Voice Ingress",
  "id": "900018",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "voice-task",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook",
      "name": "Voice Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [224, 288]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const body = $input.first().json\nconst prompt = String(body.prompt || '').trim()\n\nif (!prompt) {\n  return {\n    json: { error: 'Empty prompt' },\n  }\n}\n\nconst taskKey = `voice-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 8)}`\nconst queuedAt = new Date().toISOString()\n\nconst contextJson = JSON.stringify({\n  source: 'voice',\n  originalPrompt: prompt,\n})\n\nreturn {\n  json: {\n    taskKey,\n    prompt,\n    contextJson,\n    queuedAt,\n    replyText: `🎤 Задача <code>${taskKey}</code> поставлена голосом`,\n  },\n}"
      },
      "id": "prepare",
      "name": "Готовим голосовую задачу",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [448, 288]
    },
    {
      "parameters": {
        "operation": "insert",
        "dataTableId": {"mode": "id", "value": "__TASKS_TABLE_ID__"},
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "task_key": "={{ $json.taskKey }}",
            "source": "voice",
            "chat_id": "voice",
            "worker_alias": "={{ $('Задаём конфигурацию OpenCode') ? $('Задаём конфигурацию OpenCode').first().json.defaultWorker : 'primary' }}",
            "command_name": "task",
            "prompt": "={{ $json.prompt }}",
            "parent_task_key": "",
            "parent_match_text": "",
            "context_json": "={{ $json.contextJson }}",
            "pending_question": "",
            "pending_options_json": "[]",
            "status": "queued",
            "queued_at": "={{ $json.queuedAt }}"
          }
        },
        "options": {}
      },
      "id": "insert-task",
      "name": "Вставляем задачу",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
      "position": [672, 288]
    },
    {
      "parameters": {
        "resource": "service",
        "operation": "call",
        "domain": "notify",
        "service": "notify",
        "serviceAttributes": {
          "message": "={{ $('Готовим голосовую задачу').item.json.replyText }}",
          "title": "n8n Ассистент"
        }
      },
      "id": "ha-notify",
      "name": "Уведомление через HA",
      "type": "n8n-nodes-base.homeAssistant",
      "typeVersion": 1,
      "position": [896, 288],
      "credentials": {
        "homeAssistantApi": {
          "id": "__HA_CREDENTIAL_ID__",
          "name": "__HA_CREDENTIAL_NAME__"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ status: 'ok', taskKey: $json.taskKey, replyText: $json.replyText }) }}",
        "options": {}
      },
      "id": "respond",
      "name": "Отвечаем HA",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1120, 288]
    }
  ],
  "connections": {
    "Voice Webhook": {
      "main": [[{"node": "Готовим голосовую задачу", "type": "main", "index": 0}]]
    },
    "Готовим голосовую задачу": {
      "main": [[{"node": "Вставляем задачу", "type": "main", "index": 0}]]
    },
    "Вставляем задачу": {
      "main": [[{"node": "Уведомление через HA", "type": "main", "index": 0}]]
    },
    "Уведомление через HA": {
      "main": [[{"node": "Отвечаем HA", "type": "main", "index": 0}]]
    }
  },
  "pinData": {},
  "active": true,
  "settings": {"executionOrder": "v1"},
  "tags": []
}
